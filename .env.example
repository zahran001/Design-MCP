# URL of the Chakra UI documentation to start crawling from
START_URL=https://chakra-ui.com/docs/components/concepts/overview

# Maximum number of pages to crawl (use -1 for unlimited)
MAX_PAGES=100

# REQUIRED: Crawl URL pattern - only URLs starting with this pattern will be followed
#
# Examples:
#   - To crawl all components: https://chakra-ui.com/docs/components/
CRAWL_URL_PATTERN=https://chakra-ui.com/docs/components/

# Optional: Control the crawling delay between pages (in milliseconds)
CRAWL_DELAY=1000

# Enable debug logging
DEBUG=true

# OpenAI API configuration for embeddings
OPENAI_API_KEY=sk-...your-key-here...

# Qdrant vector database configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=chakra-ui-docs
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# Required only for Qdrant Cloud (local docker-compose Qdrant needs none).
# QDRANT_API_KEY=...your-qdrant-cloud-key...

# Step 4 generation (defaults shown; uncomment to override)
# GEN_MODEL=gpt-4o
# EVAL_JUDGE_MODEL=gpt-4o-mini
# Generation provider: leave GEN_BASE_URL unset for OpenAI (byte-identical gpt-4o
# path). Set it to route generation (NOT embeddings) at DeepSeek V4 — embeddings
# stay on OpenAI because the corpus is text-embedding-3-small (1536-dim).
# GEN_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=sk-...your-deepseek-key...
# GEN_MODEL=deepseek-v4-pro
# Thinking is verified OFF (already clears the bar); flip only with a measured reason.
# GEN_THINKING=false
# REPAIR_THINKING=false
# Set RENDER_CHECK=false to skip the Chromium render-check (prod has no Chromium;
# Sandpack renders client-side, tsc stays the gate). Unset/anything-else = on.
# RENDER_CHECK=false
# Override the static SPA dir the server serves (defaults to web/dist).
# WEB_DIST=web/dist
# Generation sampling. Product default temp is 0.2 (variety is a feature). The
# eval harnesses (run-ab / run-heldout) force temp 0 + seed 42 in code for a
# stable measurement, regardless of these. Set GEN_TEMP/GEN_SEED only to override
# the PRODUCT CLI (npm run cli -- 4-generate) — e.g. for a reproducible demo.
# GEN_TEMP=0.2
# GEN_SEED=