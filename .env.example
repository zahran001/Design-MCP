# URL of the Chakra UI documentation to start crawling from
START_URL=https://chakra-ui.com/docs/components/concepts/overview

# Maximum number of pages to crawl (use -1 for unlimited)
MAX_PAGES=100

# REQUIRED: Crawl URL pattern - only URLs starting with this pattern will be followed
#
# Examples:
#   - To crawl all components: https://chakra-ui.com/docs/components/
CRAWL_URL_PATTERN=https://chakra-ui.com/docs/components/

# Optional: Control the crawling delay between pages (in milliseconds)
CRAWL_DELAY=1000

# Debug logging. Keep FALSE for any embed/search/generate run (else the OpenAI SDK
# floods stdout). Set true only when debugging the step-0 crawl.
DEBUG=false

# === LLM provider keys ===
# OpenAI — REQUIRED. Embeddings are ALWAYS OpenAI (the corpus is
# text-embedding-3-small / 1536-dim; the query embedding must match the stored
# vectors), regardless of which model does generation below.
OPENAI_API_KEY=sk-...your-openai-key...

# DeepSeek — REQUIRED in the current setup: generation/repair runs on DeepSeek V4
# (see GEN_BASE_URL under Step 4). Omit only if you fall back to OpenAI generation.
DEEPSEEK_API_KEY=sk-...your-deepseek-key...

# Qdrant vector database configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=chakra-ui-docs
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# Required only for Qdrant Cloud (local docker-compose Qdrant needs none).
# QDRANT_API_KEY=...your-qdrant-cloud-key...

# === Step 4 generation ===
# Generation/repair runs on DeepSeek V4 (OpenAI-API compatible — same SDK, different
# base URL + key). Embeddings stay OpenAI (above). To fall back to OpenAI gpt-4o,
# comment out BOTH lines below: GEN_BASE_URL alone is not enough — GEN_MODEL would
# default to gpt-4o and DeepSeek would 400 on an unknown model name.
GEN_BASE_URL=https://api.deepseek.com
GEN_MODEL=deepseek-v4-pro

# DeepSeek "thinking mode" (generate / repair). Keep OFF: a 2026-06-30 A/B on the 15
# landmines found NO objective-gate gain and ~+46% latency. Flip only with a measured
# reason (see GENERATION_EXPERIMENT.md "DeepSeek thinking-mode A/B").
# GEN_THINKING=false
# REPAIR_THINKING=false

# LLM-as-judge model for the retrieval eval (secondary signal — untrusted on v3).
# EVAL_JUDGE_MODEL=gpt-4o-mini

# Render-check (Tier-3 headless mount). Leave ON locally (default = on when unset).
# Prod sets false: no Chromium in the image, Sandpack renders client-side, tsc stays
# the objective gate.
# RENDER_CHECK=false

# Override the static SPA dir the server (4-serve) serves (defaults to web/dist).
# WEB_DIST=web/dist

# Generation sampling. Product default temp is 0.2 (variety is a feature). The eval
# harnesses (run-ab / run-heldout) force temp 0 + seed 42 in code regardless of these.
# Set GEN_TEMP/GEN_SEED only to override the PRODUCT CLI (npm run cli -- 4-generate),
# e.g. a reproducible demo. NOTE: DeepSeek treats seed/temperature as best-effort (not
# documented), so reproducibility is weaker on the DeepSeek path.
# GEN_TEMP=0.2
# GEN_SEED=