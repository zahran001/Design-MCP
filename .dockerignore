# Node modules (root AND nested, e.g. web/node_modules — else it bloats the
# build context: the prod image installs deps fresh in the builder stage)
**/node_modules

# Environment variables
.env

# IDE files
.vscode/
.idea/

# Git files
.git/
.gitignore

# Project specific (all generated artifacts — keep the Docker build context clean)
artifacts/
stores/*
test-results/
playwright-report/

# gen-sandbox: the prod image needs ONLY tsconfig.json (the tsc validator points
# at it). Exclude the validator's scratch — render/ holds esbuild/Playwright temp
# files that don't tar cleanly, and generated.tsx is a per-run leftover.
gen-sandbox/render/
gen-sandbox/generated.tsx
gen-sandbox/*.tsbuildinfo

# Build artifacts
dist/
web/dist/
*.log